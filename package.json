{
  "name": "@anycast-guide/lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/sync-native-artifacts.mjs && tsc -b && vite build",
    "build:required": "ANYCAST_LAB_NATIVE_MODE=local ANYCAST_LAB_REQUIRE_NATIVE=1 bun run build",
    "preview": "vite preview",
    "test": "vitest run --testTimeout=20000 --hookTimeout=20000",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:bird-abi": "./appliances/bird/scripts/test-native-harness.sh",
    "build:v86-image": "./appliances/v86/scripts/build-image.sh",
    "sync:v86-image": "node scripts/sync-native-artifacts.mjs",
    "lint": "eslint .",
    "check": "tsc -b --pretty false",
    "verify": "bun run check && bun run lint && bun run test && bun run test:bird-abi && bun run build && bun run test:e2e",
    "verify:native": "bun run build:v86-image && bun run build:required && ANYCAST_LAB_REQUIRE_NATIVE=1 playwright test e2e/native-vm.spec.ts",
    "verify:full": "bun run verify && bun run verify:native"
  },
  "dependencies": {
    "@xyflow/react": "^12.8.5",
    "fflate": "^0.8.2",
    "idb": "^8.0.3",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "v86": "0.5.424",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.19.1",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
