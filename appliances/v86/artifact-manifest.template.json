{
  "schemaVersion": 1,
  "imageId": "anycast-lab-router",
  "buildId": "@IMAGE_BUILD_ID@",
  "sourceDateEpoch": @SOURCE_DATE_EPOCH@,
  "buildroot": {
    "version": "@BUILDROOT_VERSION@",
    "sha256": "@BUILDROOT_SHA256@"
  },
  "v86": {
    "packageVersion": "@V86_NPM_VERSION@",
    "commit": "@V86_COMMIT@"
  },
  "daemons": {
    "bird": "@BIRD_VERSION@",
    "frr": "@FRR_VERSION@"
  },
  "toolchain": {
    "scope": "bird-and-frr",
    "compiler": "clang",
    "compilerVersion": "@LLVM_VERSION@",
    "linker": "lld",
    "optimization": "O3",
    "lto": "thin"
  },
  "pgo": {
    "mode": "@PGO_MODE@",
    "contextSha256": "@PGO_CONTEXT_SHA@",
    "profileSetBuildKey": @PGO_PROFILE_SET_BUILD_KEY_JSON@,
    "birdProfileSha256": @BIRD_PROFILE_SHA256_JSON@,
    "frrProfileSha256": @FRR_PROFILE_SHA256_JSON@
  },
  "machine": {
    "model": "shared-namespaces",
    "memoryBytes": @GUEST_MEMORY_BYTES@,
    "vgaMemoryBytes": 2097152,
    "trunkMtu": 65535
  },
  "filesystem": @FILESYSTEM_JSON@,
  "artifacts": [
    {
      "id": "v86-wasm",
      "file": "v86.wasm",
      "size": @V86_WASM_SIZE@,
      "sha256": "@V86_WASM_OUTPUT_SHA256@"
    },
    {
      "id": "bios",
      "file": "seabios.bin",
      "size": @SEABIOS_SIZE@,
      "sha256": "@SEABIOS_OUTPUT_SHA256@"
    },
    {
      "id": "vga-bios",
      "file": "vgabios.bin",
      "size": @VGABIOS_SIZE@,
      "sha256": "@VGABIOS_OUTPUT_SHA256@"
    },
    {
      "id": "bzimage",
      "file": "router-bzimage.bin",
      "size": @BZIMAGE_SIZE@,
      "sha256": "@BZIMAGE_SHA256@"
    }
  ]
}
