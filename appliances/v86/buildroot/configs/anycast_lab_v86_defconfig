BR2_x86_pentiumpro=y
BR2_TOOLCHAIN_BUILDROOT_GLIBC=y
BR2_PACKAGE_HOST_LINUX_HEADERS_CUSTOM_6_18=y
BR2_GLOBAL_PATCH_DIR="board/qemu/patches"
BR2_DOWNLOAD_FORCE_CHECK_HASHES=y
BR2_REPRODUCIBLE=y
BR2_TARGET_GENERIC_HOSTNAME="anycastlab"
BR2_TARGET_GENERIC_ISSUE="Anycast Lab router appliance"
BR2_TARGET_GENERIC_GETTY_PORT="ttyS0"
BR2_TARGET_GENERIC_GETTY_BAUDRATE_115200=y
BR2_TARGET_GENERIC_GETTY_OPTIONS="-n -l /bin/sh"
BR2_SYSTEM_DHCP=""
BR2_ROOTFS_OVERLAY="$(BR2_EXTERNAL_ANYCAST_LAB_PATH)/board/rootfs-overlay"
BR2_ROOTFS_POST_BUILD_SCRIPT="$(BR2_EXTERNAL_ANYCAST_LAB_PATH)/board/post-build.sh"
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_CUSTOM_VERSION=y
BR2_LINUX_KERNEL_CUSTOM_VERSION_VALUE="6.18.7"
BR2_LINUX_KERNEL_USE_CUSTOM_CONFIG=y
BR2_LINUX_KERNEL_CUSTOM_CONFIG_FILE="$(BR2_EXTERNAL_ANYCAST_LAB_PATH)/board/linux.config"
BR2_LINUX_KERNEL_NEEDS_HOST_LIBELF=y
BR2_TARGET_ROOTFS_INITRAMFS=y
BR2_TARGET_ROOTFS_CPIO_GZIP=y
# BR2_TARGET_ROOTFS_TAR is not set
BR2_PACKAGE_IPROUTE2=y
BR2_PACKAGE_IPUTILS=y
BR2_PACKAGE_TRACEROUTE=y
BR2_PACKAGE_TCPDUMP=y
BR2_PACKAGE_ETHTOOL=y
BR2_PACKAGE_BIRD=y
BR2_PACKAGE_BIRD_CLIENT=y
BR2_PACKAGE_BIRD_BABEL=y
BR2_PACKAGE_BIRD_BFD=y
BR2_PACKAGE_BIRD_BGP=y
BR2_PACKAGE_BIRD_MRT=y
BR2_PACKAGE_BIRD_OSPF=y
BR2_PACKAGE_BIRD_PIPE=y
BR2_PACKAGE_BIRD_RADV=y
BR2_PACKAGE_BIRD_RIP=y
BR2_PACKAGE_BIRD_RPKI=y
BR2_PACKAGE_BIRD_STATIC=y
BR2_PACKAGE_FRR=y
BR2_PACKAGE_FRR_BFD=y
# BR2_PACKAGE_FRR_PROTOBUF is not set
BR2_PACKAGE_LIBCAP=y
