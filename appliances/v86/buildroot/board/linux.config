# Anycast Lab's browser guest is a known, single-vCPU virtual machine. Keep
# this as an explicit appliance configuration rather than inheriting the broad
# x86 defaults: Buildroot feeds this file through olddefconfig.

# Small, deterministic uniprocessor kernel.
CONFIG_EXPERT=y
CONFIG_BASE_SMALL=y
# CONFIG_LOCALVERSION_AUTO is not set
# CONFIG_SMP is not set
# CONFIG_HOTPLUG_CPU is not set
CONFIG_PREEMPT_NONE=y
# CONFIG_PREEMPT_DYNAMIC is not set
CONFIG_HZ_100=y
# CONFIG_HZ_250 is not set
CONFIG_CC_OPTIMIZE_FOR_SIZE=y
# CONFIG_CC_OPTIMIZE_FOR_PERFORMANCE is not set
CONFIG_LOG_BUF_SHIFT=14
# CONFIG_KALLSYMS is not set
# x86 selects the perf core unconditionally; omit every hardware PMU backend.
# CONFIG_PERF_EVENTS_INTEL_UNCORE is not set
# CONFIG_PERF_EVENTS_INTEL_RAPL is not set
# CONFIG_PERF_EVENTS_INTEL_CSTATE is not set
# CONFIG_PERF_EVENTS_AMD_POWER is not set
# CONFIG_PERF_EVENTS_AMD_UNCORE is not set
# CONFIG_PERF_EVENTS_AMD_BRS is not set
# CONFIG_AIO is not set
# CONFIG_IO_URING is not set
# CONFIG_CROSS_MEMORY_ATTACH is not set
# CONFIG_FHANDLE is not set
# CONFIG_CACHESTAT_SYSCALL is not set
# CONFIG_COREDUMP is not set
# CONFIG_SWAP is not set
# CONFIG_COMPACTION is not set
# CONFIG_MIGRATION is not set
# CONFIG_SECRETMEM is not set
# CONFIG_SYSFS_SYSCALL is not set
# CONFIG_PCSPKR_PLATFORM is not set
# CONFIG_SGETMASK_SYSCALL is not set
# CONFIG_UID16 is not set

# Process model, namespaces, cgroup v2 controllers, and syscall isolation.
CONFIG_MULTIUSER=y
CONFIG_SYSVIPC=y
# CONFIG_POSIX_MQUEUE is not set
CONFIG_FUTEX=y
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_SHMEM=y
CONFIG_ADVISE_SYSCALLS=y
CONFIG_MEMBARRIER=y
# Native BIRD/FRR binaries and their service wrappers are the whole point of
# the guest; pin both execution formats instead of relying on Kconfig defaults.
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y
# CONFIG_BINFMT_MISC is not set
# CONFIG_RSEQ is not set
CONFIG_CGROUPS=y
CONFIG_MEMCG=y
# CONFIG_MEMCG_V1 is not set
CONFIG_CGROUP_SCHED=y
CONFIG_FAIR_GROUP_SCHED=y
CONFIG_CFS_BANDWIDTH=y
CONFIG_CGROUP_PIDS=y
# CONFIG_BLK_CGROUP is not set
# CONFIG_CGROUP_RDMA is not set
# CONFIG_CGROUP_DMEM is not set
# CONFIG_CPUSETS is not set
# CONFIG_CGROUP_DEVICE is not set
# CONFIG_CGROUP_CPUACCT is not set
# CONFIG_CGROUP_PERF is not set
# CONFIG_CGROUP_MISC is not set
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_TIME_NS=y
CONFIG_IPC_NS=y
# The outer v86 guest is the security boundary. Node roots need privileged
# overlay/devpts/sysfs setup in the initial user namespace, so compiling an
# unused nested user-namespace surface only adds kernel code and attack area.
# CONFIG_USER_NS is not set
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
# CONFIG_SECCOMP_CACHE_DEBUG is not set
# CONFIG_CHECKPOINT_RESTORE is not set
# CONFIG_AUDIT is not set
# CONFIG_SECURITY is not set
CONFIG_DEFAULT_SECURITY_DAC=y
CONFIG_SECURITY_DMESG_RESTRICT=y
CONFIG_STACKPROTECTOR_STRONG=y
CONFIG_STRICT_KERNEL_RWX=y
# CONFIG_DEVMEM is not set
# CONFIG_DEVPORT is not set

# The immutable SquashFS root is an external IDE disk.  Keep the kernel free of
# a second root-image path and its decompressor; only the bzImage itself uses
# gzip compression.
# CONFIG_MODULES is not set
# CONFIG_BLK_DEV_INITRD is not set
# CONFIG_RD_GZIP is not set
# CONFIG_RD_BZIP2 is not set
# CONFIG_RD_LZMA is not set
# CONFIG_RD_XZ is not set
# CONFIG_RD_LZO is not set
# CONFIG_RD_LZ4 is not set
# CONFIG_RD_ZSTD is not set
# CONFIG_INITRAMFS_COMPRESSION_GZIP is not set
# CONFIG_INITRAMFS_PRESERVE_MTIME is not set
CONFIG_KERNEL_GZIP=y

# x86 features needed by v86/SeaBIOS; omit host-only power and telemetry.
CONFIG_X86_32=y
CONFIG_M686=y
CONFIG_RELOCATABLE=y
CONFIG_RANDOMIZE_BASE=y
CONFIG_X86_UP_APIC=y
CONFIG_X86_UP_IOAPIC=y
CONFIG_X86_LOCAL_APIC=y
CONFIG_X86_IO_APIC=y
CONFIG_X86_TSC=y
CONFIG_X86_CMOV=y
CONFIG_PROCESSOR_SELECT=y
CONFIG_CPU_SUP_INTEL=y
# v86 identifies itself as GenuineIntel/Pentium III.
# CONFIG_CPU_SUP_AMD is not set
# CONFIG_CPU_SUP_CYRIX_32 is not set
# CONFIG_CPU_SUP_HYGON is not set
# CONFIG_CPU_SUP_CENTAUR is not set
# CONFIG_CPU_SUP_TRANSMETA_32 is not set
# CONFIG_CPU_SUP_UMC_32 is not set
# CONFIG_CPU_SUP_ZHAOXIN is not set
# CONFIG_CPU_SUP_VORTEX_32 is not set
# CONFIG_X86_MCE is not set
# CONFIG_HPET_TIMER is not set
# CONFIG_MTRR is not set
# CONFIG_X86_PAT is not set
# CONFIG_MODIFY_LDT_SYSCALL is not set
# CONFIG_X86_BUS_LOCK_DETECT is not set
# CONFIG_CPU_MITIGATIONS is not set
# CONFIG_HYPERVISOR_GUEST is not set
# CONFIG_PARAVIRT is not set
# CONFIG_KVM_GUEST is not set
# CONFIG_X86_16BIT is not set
# CONFIG_X86_IOPL_IOPERM is not set
# CONFIG_SUSPEND is not set
# CONFIG_PM is not set
# CONFIG_CPU_FREQ is not set
# CONFIG_CPU_IDLE is not set

# v86 exposes fixed legacy PCI configuration space and the emulator is started
# with ACPI disabled.  Scan it directly and omit physical-machine workarounds.
CONFIG_PCI=y
CONFIG_PCI_GODIRECT=y
# CONFIG_PCI_GOANY is not set
# CONFIG_PCI_BIOS is not set
CONFIG_PCI_DIRECT=y
# CONFIG_PCI_QUIRKS is not set
# CONFIG_PCIEASPM is not set
# CONFIG_PCI_LABEL is not set
# CONFIG_VGA_ARB is not set
# CONFIG_ACPI is not set
# CONFIG_PNP is not set
# CONFIG_DMI is not set
# CONFIG_IOMMU_SUPPORT is not set
# CONFIG_FW_LOADER is not set
# CONFIG_STANDALONE is not set

# Raw immutable SquashFS root on the one v86 IDE disk.
CONFIG_BLOCK=y
# CONFIG_BLK_DEV_WRITE_MOUNTED is not set
CONFIG_PARTITION_ADVANCED=y
# CONFIG_BLOCK_LEGACY_AUTOLOAD is not set
CONFIG_BLK_DEV=y
# CONFIG_BLK_DEV_LOOP is not set
# CONFIG_VIRTIO_BLK is not set
# CONFIG_MQ_IOSCHED_DEADLINE is not set
# CONFIG_MQ_IOSCHED_KYBER is not set
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
# CONFIG_CHR_DEV_SG is not set
# CONFIG_SCSI_PROC_FS is not set
# CONFIG_BLK_DEV_BSG is not set
# CONFIG_SCSI_LOWLEVEL is not set
CONFIG_ATA=y
CONFIG_ATA_SFF=y
CONFIG_ATA_BMDMA=y
CONFIG_ATA_PIIX=y
CONFIG_ATA_GENERIC=y
# CONFIG_SATA_AHCI is not set
# CONFIG_SATA_PMP is not set
# CONFIG_ATA_VERBOSE_ERROR is not set
# CONFIG_ATA_FORCE is not set
# CONFIG_PATA_LEGACY is not set
# CONFIG_BLK_DEV_NVME is not set
# CONFIG_MSDOS_PARTITION is not set
# CONFIG_EFI_PARTITION is not set

# Networking required by routing daemons and the browser VLAN trunk.
CONFIG_NET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_INET=y
CONFIG_IP_MULTICAST=y
CONFIG_IP_ADVANCED_ROUTER=y
CONFIG_IP_MULTIPLE_TABLES=y
CONFIG_IP_ROUTE_MULTIPATH=y
CONFIG_IP_MROUTE=y
CONFIG_INET_DIAG=y
CONFIG_INET_TCP_DIAG=y
CONFIG_IPV6=y
# CONFIG_IPV6_SIT is not set
CONFIG_IPV6_MULTIPLE_TABLES=y
CONFIG_IPV6_SUBTREES=y
CONFIG_NETDEVICES=y
CONFIG_DUMMY=y
CONFIG_VETH=y
CONFIG_TUN=y
CONFIG_IFB=y
CONFIG_VIRTIO_NET=y
CONFIG_VLAN_8021Q=y
CONFIG_BRIDGE=y
# CONFIG_BRIDGE_IGMP_SNOOPING is not set
# CONFIG_BRIDGE_VLAN_FILTERING is not set
CONFIG_NET_L3_MASTER_DEV=y
CONFIG_NET_VRF=y
# CONFIG_NETFILTER is not set
# CONFIG_ETHERNET is not set
# CONFIG_WIRELESS is not set
# CONFIG_WLAN is not set
# CONFIG_ETHTOOL_NETLINK is not set
# CONFIG_NET_9P_FD is not set

# Per-link delay, loss, bandwidth, and optional ingress redirection.
CONFIG_NET_SCHED=y
CONFIG_NET_SCH_HTB=y
CONFIG_NET_SCH_TBF=y
CONFIG_NET_SCH_NETEM=y
CONFIG_NET_SCH_INGRESS=y
CONFIG_NET_CLS_U32=y
CONFIG_NET_CLS_ACT=y
CONFIG_NET_ACT_GACT=y
CONFIG_NET_ACT_MIRRED=y

# v86 host control plane and console devices. v86 exposes legacy virtio PCI.
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_PCI_LEGACY=y
# CONFIG_VIRTIO_MMIO is not set
# CONFIG_VIRTIO_BALLOON is not set
CONFIG_NET_9P=y
CONFIG_NET_9P_VIRTIO=y
CONFIG_9P_FS=y
# CONFIG_9P_FS_POSIX_ACL is not set
CONFIG_TTY=y
CONFIG_UNIX98_PTYS=y
# CONFIG_LEGACY_PTYS is not set
# CONFIG_LEGACY_TIOCSTI is not set
# CONFIG_LDISC_AUTOLOAD is not set
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_NR_UARTS=1
CONFIG_SERIAL_8250_RUNTIME_UARTS=1
# CONFIG_SERIAL_8250_DEPRECATED_OPTIONS is not set
# CONFIG_SERIAL_8250_PNP is not set
# CONFIG_SERIAL_8250_PCI is not set
# CONFIG_SERIAL_8250_EXAR is not set
# CONFIG_SERIAL_8250_DWLIB is not set
# CONFIG_SERIAL_8250_LPSS is not set
# CONFIG_SERIAL_8250_MID is not set
# CONFIG_SERIAL_8250_PERICOM is not set
CONFIG_VIRTIO_CONSOLE=y
# CONFIG_HW_RANDOM is not set

# Filesystems used by isolated nodes and optional immutable external images.
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
# CONFIG_ALLOW_DEV_COREDUMP is not set
CONFIG_PROC_FS=y
CONFIG_PROC_SYSCTL=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y
# CONFIG_TMPFS_POSIX_ACL is not set
CONFIG_TMPFS_XATTR=y
# CONFIG_FS_POSIX_ACL is not set
CONFIG_FILE_LOCKING=y
CONFIG_INOTIFY_USER=y
# CONFIG_DNOTIFY is not set
# CONFIG_EXT4_FS is not set
# CONFIG_EROFS_FS is not set
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_FILE_DIRECT=y
CONFIG_SQUASHFS_COMPILE_DECOMP_SINGLE=y
CONFIG_SQUASHFS_EMBEDDED=y
CONFIG_SQUASHFS_FRAGMENT_CACHE_SIZE=1
# CONFIG_SQUASHFS_XATTR is not set
# CONFIG_SQUASHFS_ZLIB is not set
# CONFIG_SQUASHFS_LZ4 is not set
# CONFIG_SQUASHFS_LZO is not set
# CONFIG_SQUASHFS_XZ is not set
CONFIG_SQUASHFS_ZSTD=y
CONFIG_ZSTD_DECOMPRESS=y
CONFIG_OVERLAY_FS=y
# CONFIG_OVERLAY_FS_REDIRECT_DIR is not set
# CONFIG_OVERLAY_FS_REDIRECT_ALWAYS_FOLLOW is not set
# CONFIG_OVERLAY_FS_INDEX is not set
# CONFIG_OVERLAY_FS_METACOPY is not set
# CONFIG_OVERLAY_FS_NFS_EXPORT is not set
# CONFIG_OVERLAY_FS_DEBUG is not set
# CONFIG_FUSE_FS is not set
# CONFIG_NFS_FS is not set
# CONFIG_CIFS is not set
# CONFIG_NLS is not set
# CONFIG_PROC_PAGE_MONITOR is not set

# There is no browser keyboard, display, USB bus, audio, or physical sensor.
# CONFIG_INPUT is not set
# CONFIG_SERIO is not set
# CONFIG_VT is not set
# CONFIG_VGA_CONSOLE is not set
# CONFIG_HID_SUPPORT is not set
# CONFIG_USB_SUPPORT is not set
# CONFIG_DRM is not set
# CONFIG_FB is not set
# CONFIG_SOUND is not set
# CONFIG_MEDIA_SUPPORT is not set
# CONFIG_I2C is not set
# CONFIG_SPI is not set
# CONFIG_GPIOLIB is not set
# CONFIG_PPS is not set
# CONFIG_PTP_1588_CLOCK is not set
# CONFIG_POWER_SUPPLY is not set
# CONFIG_HWMON is not set
# CONFIG_THERMAL is not set

# Retain useful stack traces, but omit dynamic tracing and allocator/debug
# instrumentation from the production appliance.
CONFIG_UNWINDER_FRAME_POINTER=y
CONFIG_SLUB_TINY=y
# CONFIG_X86_VERBOSE_BOOTUP is not set
# CONFIG_EARLY_PRINTK is not set
CONFIG_DEBUG_KERNEL=y
# CONFIG_DEBUG_MISC is not set
# CONFIG_DEBUG_BUGVERBOSE is not set
# CONFIG_SLUB_DEBUG is not set
# CONFIG_DEBUG_MEMORY_INIT is not set
# CONFIG_DEBUG_FS is not set
# CONFIG_MAGIC_SYSRQ is not set
# CONFIG_FTRACE is not set
# CONFIG_KPROBES is not set
# CONFIG_UPROBES is not set
# CONFIG_GCOV_KERNEL is not set
# CONFIG_X86_DEBUG_FPU is not set
