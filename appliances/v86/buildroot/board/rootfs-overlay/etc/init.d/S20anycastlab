#!/bin/sh

HOST_MOUNT=/mnt/anycast-host
BOOTSTRAP="$HOST_MOUNT/anycastlab-bootstrap.tar"

fail() {
  reason=$1
  echo "anycastlab: $reason" >/dev/ttyS0
  printf 'ANYCASTLAB/1 FAILED %s\n' "$reason" >/dev/hvc0 2>/dev/null || true
  exit 1
}

case "${1:-start}" in
  start)
    mkdir -p "$HOST_MOUNT" /run/anycastlab
    if ! mount -t 9p -o trans=virtio,version=9p2000.L,cache=none host9p "$HOST_MOUNT"; then
      fail host-channel-mount
    fi
    if [ ! -f "$BOOTSTRAP" ]; then
      fail bootstrap-missing
    fi
    if tar -tf "$BOOTSTRAP" | grep -Eq '(^/|(^|/)\.\.(/|$))'; then
      fail bootstrap-unsafe
    fi
    tar -xpf "$BOOTSTRAP" -C / || fail bootstrap-extract
    /run/anycastlab/start.sh || fail appliance-readiness
    /usr/libexec/anycastlab-agent </dev/hvc0 >/dev/hvc0 2>&1 &
    ;;
  stop)
    if [ -f /run/anycastlab/appliance.pid ]; then
      kill "$(cat /run/anycastlab/appliance.pid)" 2>/dev/null || true
    fi
    ;;
esac
