#!/bin/sh
set -eu

HOST_MOUNT=/run/anycast-host
RUNTIME=/run/anycastlab
PID_FILE=$RUNTIME/labd.pid
BOOTSTRAP=$HOST_MOUNT/anycastlab-shared-bootstrap.tar

fail() {
  echo "anycastlab: $1" >/dev/ttyS0 2>/dev/null || true
  exit 1
}

case "${1:-start}" in
  start)
    mkdir -p "$HOST_MOUNT" "$RUNTIME"
    chmod 0700 "$RUNTIME"
    if ! grep -F " $HOST_MOUNT 9p " /proc/mounts >/dev/null 2>&1; then
      mount -t 9p -o trans=virtio,version=9p2000.L,cache=none host9p "$HOST_MOUNT" ||
        fail host-channel-mount
    fi
    [ -f "$BOOTSTRAP" ] || fail shared-bootstrap-missing
    [ ! -e "$PID_FILE" ] || fail stale-supervisor-pid
    /usr/sbin/anycast-labd </dev/null >/dev/ttyS0 2>&1 &
    pid=$!
    printf '%s\n' "$pid" >"$PID_FILE"
    kill -0 "$pid" 2>/dev/null || fail supervisor-start
    ;;
  stop)
    if [ -r "$PID_FILE" ]; then
      pid=$(cat "$PID_FILE")
      kill "$pid" 2>/dev/null || true
      attempt=0
      while kill -0 "$pid" 2>/dev/null && [ "$attempt" -lt 5 ]; do
        attempt=$((attempt + 1))
        sleep 1
      done
      kill -9 "$pid" 2>/dev/null || true
      rm -f "$PID_FILE"
    fi
    umount "$HOST_MOUNT" 2>/dev/null || true
    ;;
  restart)
    "$0" stop
    "$0" start
    ;;
  *)
    echo "Usage: $0 {start|stop|restart}" >&2
    exit 2
    ;;
esac
